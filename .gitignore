# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node dependencies
/node_modules/

# Yarn PnP
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
/.next/
/out/
/build/
/dist/
/.parcel-cache/

# Next.js cache
/.next/cache

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# Testing
/coverage/
.nyc_output/

# Environment files (keep examples in repo)
.env.local
.env.*.local
.env
!.env.example

# Vercel and deployment
.vercel/
.now/

# IDEs and editors
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Typescript
*.tsbuildinfo
next-env.d.ts

# Misc
*.pem
*.key
.cache/

# Other
.firebase/
